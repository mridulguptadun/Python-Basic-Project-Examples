bank.py

accounts = []

def create_account():
	acc_no = input("Enter Account Number : ")
	name = input("Enter Customer Name : ")
	balance = float(input("Enter Opening Balance : "))

	accounts.append([acc_no, name, balance])

	print("Account Created Successfully")

def show_accounts():
	if len(accounts) == 0:
		print("No Account Found")
		return
	print("\n------ Account List ------")
	for acc in accounts:
		print("Account No. :",acc[0])
		print("name :",acc[1])
		print("Balance :",acc[2])
		print("_" * 20)

def search_account():
	acc_no = input("Enter Account No. : ")
	for acc in accounts:
		if acc[0] == acc_no:
			print("Account Found")
			print(acc)
			return
	print("Account Not Found")

def deposit():
	acc_no = input("Enter Account No. : ")
	for acc in accounts:
		if acc[0] == acc_no:
			amount = float(input("Enter Desposit Amount : "))
			acc[2] += amount
			print("Amount Deposited Successfully")
			print("Your Current Balance : ", acc[2])
			return
	print("Account Not Found")

def withdraw():
	acc_no = input("Enter Account No. : ")
	for acc in accounts:
		if acc[0] == acc_no:
			amount = float(input("Enter Withdraw Amount : "))
			if amount > acc[2]:
				print("Insufficient Balance")
			else:
				acc[2] -= amount
				print("Withdrawal Successfully")
				print("Current Balance ",acc[2])
				return
	print("Account Not Found")

def transfer_money():
	sender = input("Enter Sender Account Number : ")
	receiver = input("Enter Receiver Account Number : ")
	amount = float(input("Enter Amount :"))
	snder_acc = None
	receiver_acc = None

	for acc in accounts:
		if acc[0] == sender:
			snder_acc = acc

		if acc[0] == receiver:
			receiver_acc = acc

	if snder_acc is None or receiver_acc is None:
		print("Account Not Found")
		return

	if snder_acc[2] < amount:
		print("Insufficient Balance")
		return

	snder_acc[2] -= amount
	receiver_acc[2] += amount

	print("Money Transfer Successfully")

def delete_account():
	acc_no = input("Enter Account Number : ")
	for acc in accounts:
		if acc[0] == acc_no:
			accounts.remove(acc)
			print("Account Deleted Successfully")
			return
	print("Account Not Found")


